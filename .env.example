PORT=3000

# One authorization token is enough for demo and real account lookup.
DERIV_API_TOKEN=
DERIV_ACCOUNT_ID=
DERIV_APP_ID=
DERIV_API_BASE_URL=https://api.derivws.com

# Use demo by default. Real mode must be selected explicitly in the dashboard.
DEFAULT_MODE=demo
SYMBOL=R_100
CURRENCY=USD

# Optional dashboard protection. Strongly recommended on a public droplet.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-this-before-deploying

# Strategy and risk defaults.
MIN_STAKE=0.35
BASE_STAKE_PERCENT=0.02
RISKY_STAKE_PERCENT=0.35
MARTINGALE_CAP_PERCENT=0.40
WINDOW_SIZE=20
GUIDE_FILTERS=false
STRICT_BAR_FILTERS=false
